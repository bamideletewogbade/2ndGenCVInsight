# ── NVIDIA NIM API ──────────────────────────────────────────────────────────
NVIDIA_API_KEY=your_nvidia_api_key_here

# ── Database (Neon PostgreSQL example) ─────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://user:pass@host/dbname?sslmode=require

# ── CORS ───────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins (e.g. your Vercel URL).
# Leave empty to use localhost defaults (dev only).
CORS_ORIGIN=https://your-app.vercel.app